---
import { footerLinks } from "../data/contact";

const year = new Date().getFullYear();
---

<footer class="mt-32 border-t-[3px] border-[var(--color-ink)] bg-[var(--color-cobalt)] text-[var(--color-paper)]">
  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-6 px-6 py-10 md:flex-row md:items-center">
    <div>
      <p class="font-display text-3xl leading-none">MIJAEL CAMA</p>
      <p class="mt-2 font-mono text-xs uppercase tracking-widest opacity-80">
        Full Stack Developer · Lima, Perú
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-4 font-mono text-xs uppercase tracking-widest">
      {
        footerLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="hover:underline"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <p class="font-mono text-xs uppercase tracking-widest opacity-60">© {year} · GAME OVER</p>
  </div>
</footer>
