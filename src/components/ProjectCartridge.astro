---
import type { Project } from "../data/projects";
import { toLocale } from "../i18n/config";
import { useUI } from "../i18n/ui";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const locale = toLocale(Astro.currentLocale);
const ui = useUI(locale);

const toneBg: Record<Project["cartridgeTone"], string> = {
  cobalt: "bg-cobalt text-paper",
  tomato: "bg-tomato text-paper",
  mustard: "bg-mustard text-ink",
  pink: "bg-pink text-ink",
};

const toneInverse: Record<Project["cartridgeTone"], string> = {
  cobalt: "bg-paper text-ink",
  tomato: "bg-paper text-ink",
  mustard: "bg-ink text-paper",
  pink: "bg-ink text-paper",
};
---

<article
  data-cartridge
  class={`group relative flex flex-col rounded-2xl border-[5px] border-ink overflow-hidden ${toneBg[project.cartridgeTone]}`}
  style="box-shadow: 10px 10px 0 0 var(--color-ink);"
>
  <!-- Tag superior estilo cartucho -->
  <div class={`flex items-center justify-between border-b-[4px] border-ink px-5 py-2 ${toneInverse[project.cartridgeTone]}`}>
    <span class="font-mono text-[10px] font-bold uppercase tracking-widest">
      {project.context}
    </span>
    <span class="font-mono text-[10px] font-bold uppercase tracking-widest opacity-70">
      {project.period}
    </span>
  </div>

  <!-- Screenshot real en marco tipo navegador (unifica capturas de temas distintos) -->
  <div class="border-b-[4px] border-ink">
    <!-- barra de navegador: traffic-lights + título -->
    <div class={`flex items-center gap-1.5 border-b-[3px] border-ink px-3 py-2 ${toneInverse[project.cartridgeTone]}`}>
      <span class="h-2.5 w-2.5 rounded-full border-[1.5px] border-ink bg-tomato"></span>
      <span class="h-2.5 w-2.5 rounded-full border-[1.5px] border-ink bg-mustard"></span>
      <span class="h-2.5 w-2.5 rounded-full border-[1.5px] border-ink bg-cobalt"></span>
      <span class="ml-2 truncate font-mono text-[9px] font-bold uppercase tracking-widest opacity-70">
        {project.subtitle}
      </span>
    </div>
    <!-- captura: 2:1 = casi sin recorte; object-top protege headers/KPIs -->
    <div class="relative aspect-[2/1] overflow-hidden bg-ink">
      <img
        src={project.screenshot}
        alt={project.screenshotAlt}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover object-top"
      />
      {project.highlight && (
        <span
          class="absolute -right-2 -top-2 z-10 rotate-6 rounded-md border-[3px] border-ink bg-mustard px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-widest text-ink"
          style="box-shadow: 2px 2px 0 0 var(--color-ink);"
        >
          {ui.gameSelect.featured}
        </span>
      )}
    </div>
  </div>

  <!-- Body: caso de estudio -->
  <div class="flex flex-1 flex-col gap-5 p-6">
    <div>
      <h3 class="font-display text-2xl leading-tight md:text-3xl">
        {project.title}
      </h3>
      <p class="mt-1 font-mono text-xs uppercase tracking-widest opacity-80">
        {project.subtitle}
      </p>
    </div>

    <!-- Problema -->
    <div>
      <p class="font-mono text-[10px] font-bold uppercase tracking-widest opacity-70">
        {ui.gameSelect.problemLabel}
      </p>
      <p class="mt-1.5 text-sm leading-relaxed opacity-95">
        {project.problem}
      </p>
    </div>

    <!-- Solución -->
    <div>
      <p class="font-mono text-[10px] font-bold uppercase tracking-widest opacity-70">
        {ui.gameSelect.solutionLabel}
      </p>
      <p class="mt-1.5 text-sm leading-relaxed opacity-95">
        {project.solution}
      </p>
    </div>

    <!-- Impacto (métricas) -->
    {project.metrics && (
      <div>
        <p class="font-mono text-[10px] font-bold uppercase tracking-widest opacity-70">
          {ui.gameSelect.impactLabel}
        </p>
        <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
          {project.metrics.map((m) => (
            <div class={`rounded-md border-[2px] border-ink px-2 py-1.5 ${toneInverse[project.cartridgeTone]}`}>
              <p class="font-display text-lg leading-tight">{m.value}</p>
              <p class="font-mono text-[9px] uppercase tracking-widest opacity-70">
                {m.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Stack -->
    <div>
      <p class="font-mono text-[10px] font-bold uppercase tracking-widest opacity-70">
        {ui.gameSelect.stackLabel}
      </p>
      <div class="mt-2 flex flex-wrap gap-2">
        {project.stack.map((tech) => (
          <span class={`rounded-full border-[2px] border-ink px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-widest ${toneInverse[project.cartridgeTone]}`}>
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- Rol -->
    <div class="mt-auto flex flex-wrap items-center justify-between gap-2 border-t-[3px] border-dashed border-ink pt-3">
      <span class="font-mono text-[10px] uppercase tracking-widest opacity-75">
        <span class="opacity-70">{ui.gameSelect.roleLabel}</span> {project.role}
      </span>
    </div>
  </div>
</article>

<script>
  // D25 — Hover lift + tilt 3D leve en los cartuchos, con spring physics
  import { animate, hover } from "motion";

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const finePointer = window.matchMedia("(pointer: fine)");

  if (!reducedMotion.matches && finePointer.matches) {
    const springLift = { type: "spring", stiffness: 300, damping: 22 } as const;
    const MAX_TILT_DEG = 3;

    for (const card of document.querySelectorAll<HTMLElement>("[data-cartridge]")) {
      animate(card, { transformPerspective: 900 }, { duration: 0 });

      hover(card, () => {
        animate(card, { y: -8, boxShadow: "14px 14px 0 0 var(--color-ink)" }, springLift);

        const onMove = (e: PointerEvent) => {
          const r = card.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          animate(
            card,
            { rotateX: -py * MAX_TILT_DEG * 2, rotateY: px * MAX_TILT_DEG * 2 },
            { duration: 0.2, ease: "easeOut" },
          );
        };
        card.addEventListener("pointermove", onMove, { passive: true });

        return () => {
          card.removeEventListener("pointermove", onMove);
          animate(
            card,
            { y: 0, rotateX: 0, rotateY: 0, boxShadow: "10px 10px 0 0 var(--color-ink)" },
            springLift,
          );
        };
      });
    }
  }
</script>
