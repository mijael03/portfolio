---
// MijiMascot — Vintage CRT-monitor cartoon mascot for the portfolio.
// SVG inline con estructura semántica completa: cada parte targeteable
// por id para animación CSS/Motion.
//
// Naming convention: character-perspective.
//   - "left" / "right" = character's left/right (NOT viewer's).
//   - "right hand" da el thumbs-up (aparece en el lado IZQUIERDO del viewer).
//
// Variantes:
//   - "wave" : pose actual (thumbs-up derecho + mano relajada izquierda)
//   - "thinking" : TODO (mano en barbilla, ceja arqueada)  → PlayerOne
//   - "bye"      : TODO (ambas manos arriba, ojos cerraditos) → Contact

type Variant = "wave"; // | "thinking" | "bye"

interface Props {
  variant?: Variant;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = "wave",
  class: className = "",
  ariaLabel = "MIJI mascota — monitor CRT vintage saludando con un pulgar arriba",
} = Astro.props;
