</div>

<style>
  .miji-mascot-wrap {
    position: relative;
    width: 100%;
    display: block;
  }

  .miji-mascot {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* === Animaciones idle === */

  /* Parpadeo: cada ~5s, los ojos se cierran 100ms */
  @keyframes miji-blink {
    0%,
    92%,
    100% {
      transform: scaleY(1);
    }
    94%,
    96% {
      transform: scaleY(0.08);
    }
  }

  .miji-mascot :global(#eye-left),
  .miji-mascot :global(#eye-right) {
    transform-box: fill-box;
    transform-origin: center;
    animation: miji-blink 5s ease-in-out infinite;
  }

  /* Antena: leve oscilación constante */
  @keyframes miji-antenna-sway {
    0%,
    100% {
      transform: rotate(-2deg);
    }
    50% {
      transform: rotate(2deg);
    }
  }

  .miji-mascot :global(#mascot-antenna) {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: miji-antenna-sway 3.6s ease-in-out infinite;
  }

  /* Idle bounce sutil del cuerpo entero (respira) */
  @keyframes miji-breathe {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .miji-mascot :global(#mascot) {
    animation: miji-breathe 4s ease-in-out infinite;
  }

  /* Hover: el thumbs-up se levanta un toque */
  .miji-mascot-wrap:hover :global(#hand-right),
  .miji-mascot-wrap:hover :global(#arm-right) {
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateY(-8px) rotate(-4deg);
    transform-origin: center;
    transform-box: fill-box;
  }

  /* LED: heartbeat doble-pulso constante */
  @keyframes miji-heartbeat {
    0%,
    40%,
    100% {
      transform: scale(1);
    }
    10% {
      transform: scale(1.3);
    }
    20% {
      transform: scale(1);
    }
    30% {
      transform: scale(1.2);
    }
  }

  .miji-mascot :global(#led) {
    transform-box: fill-box;
    transform-origin: center;
    animation: miji-heartbeat 2.4s ease-in-out infinite;
  }

  /* Hover: los botones del panel se "presionan" alternadamente */
  @keyframes miji-button-press {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(4px);
    }
  }

  .miji-mascot :global(#button-red),
  .miji-mascot :global(#button-yellow) {
    transform-box: fill-box;
    transform-origin: center;
  }

  .miji-mascot-wrap:hover :global(#button-red) {
    animation: miji-button-press 0.6s ease-in-out infinite;
  }

  .miji-mascot-wrap:hover :global(#button-yellow) {
    animation: miji-button-press 0.6s ease-in-out infinite;
    animation-delay: 0.3s;
  }

  /* Pupilas: el JS de mousetracking setea transform; la transición lo suaviza */
  .miji-mascot :global(#pupil-left),
  .miji-mascot :global(#pupil-right) {
    transition: transform 120ms ease-out;
  }

  /* Reduced motion: matar todo */
  @media (prefers-reduced-motion: reduce) {
    .miji-mascot :global(#eye-left),
    .miji-mascot :global(#eye-right),
    .miji-mascot :global(#mascot-antenna),
    .miji-mascot :global(#mascot),
    .miji-mascot :global(#led),
    .miji-mascot :global(#button-red),
    .miji-mascot :global(#button-yellow) {
      animation: none;
    }
  }
</style>

<script>
  // M03 — Pupilas siguen al cursor.
  // Las pupilas viven dentro de un clipPath con forma de sclera, así que
  // pueden desplazarse libremente sin salirse del ojo.
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const finePointer = window.matchMedia("(pointer: fine)");

  // Desplazamiento máximo en unidades del viewBox (645×605)
  const MAX_X = 12;
  const MAX_Y = 9;
  // Distancia (px de pantalla) a la que la mirada llega a su tope
  const FULL_DEFLECTION_PX = 260;

  function setupPupilTracking() {
    const mascots = document.querySelectorAll<SVGSVGElement>(".miji-mascot");
    if (!mascots.length) return;

    let pointerX = 0;
    let pointerY = 0;
    let raf = 0;

    const update = () => {
      raf = 0;
      for (const svg of mascots) {
        const rect = svg.getBoundingClientRect();
        // Punto de referencia: la altura de los ojos (~35% del SVG)
        const eyesX = rect.left + rect.width / 2;
        const eyesY = rect.top + rect.height * 0.35;
        const dx = pointerX - eyesX;
        const dy = pointerY - eyesY;
        const dist = Math.hypot(dx, dy);
        if (dist === 0) continue;
        const strength = Math.min(dist / FULL_DEFLECTION_PX, 1);
        const x = (dx / dist) * MAX_X * strength;
        const y = (dy / dist) * MAX_Y * strength;
        for (const pupil of svg.querySelectorAll<SVGElement>("#pupil-left, #pupil-right")) {
          pupil.style.transform = `translate(${x.toFixed(2)}px, ${y.toFixed(2)}px)`;
        }
      }
    };

    window.addEventListener(
      "pointermove",
      (e) => {
        if (reducedMotion.matches) return;
        pointerX = e.clientX;
        pointerY = e.clientY;
        if (!raf) raf = requestAnimationFrame(update);
      },
      { passive: true },
    );
  }

  if (finePointer.matches) setupPupilTracking();
</script>
