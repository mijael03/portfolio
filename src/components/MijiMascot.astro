          fill="var(--color-mustard)"
          stroke="var(--color-ink)"
          stroke-width="5"
          stroke-linejoin="round"
        ></path>
        <rect id="antenna-rod" x="383" y="23" width="9" height="46" rx="2" fill="var(--color-ink)"></rect>
        <circle id="antenna-ball" cx="388" cy="15" r="12.5" fill="var(--color-tomato)" stroke="var(--color-ink)" stroke-width="5"></circle>
        <path
          id="antenna-highlight"
          d="M383.139 11.4717C382.165 12.979 380.529 13.6539 379.485 12.9792C378.442 12.3045 378.386 10.5357 379.361 9.02837C380.335 7.52105 381.971 6.84608 383.015 7.52078C384.058 8.19548 384.114 9.96435 383.139 11.4717Z"
          fill="white"
        ></path>
