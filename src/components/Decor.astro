---
// Decoraciones reutilizables: estrellas, squiggles, dots.
// Posición/color por prop. Cero asset, todo SVG inline.

type Shape = "star" | "squiggle" | "dot" | "sparkle" | "plus";

interface Props {
  shape: Shape;
  color?: "tomato" | "cobalt" | "mustard" | "ink" | "pink" | "paper";
  size?: number;
  class?: string;
}

const { shape, color = "mustard", size = 40, class: className = "" } = Astro.props;

const colorVar = `var(--color-${color})`;
---

{shape === "star" && (
  <svg width={size} height={size} viewBox="0 0 40 40" class={`pointer-events-none ${className}`} aria-hidden="true">
    <path
      d="M 20 4 L 24 16 L 36 20 L 24 24 L 20 36 L 16 24 L 4 20 L 16 16 Z"
      fill={colorVar}
      stroke="var(--color-ink)"
      stroke-width="3"
      stroke-linejoin="round"
    />
  </svg>
)}

{shape === "sparkle" && (
  <svg width={size} height={size} viewBox="0 0 40 40" class={`pointer-events-none ${className}`} aria-hidden="true">
    <path
      d="M 20 2 L 22 18 L 38 20 L 22 22 L 20 38 L 18 22 L 2 20 L 18 18 Z"
      fill={colorVar}
      stroke="var(--color-ink)"
      stroke-width="2.5"
      stroke-linejoin="round"
    />
  </svg>
)}

{shape === "squiggle" && (
  <svg width={size * 2} height={size} viewBox="0 0 80 40" class={`pointer-events-none ${className}`} aria-hidden="true">
    <path
      d="M 4 20 Q 14 4, 24 20 T 44 20 T 64 20 T 84 20"
      stroke={colorVar}
      stroke-width="4"
      stroke-linecap="round"
      fill="none"
    />
  </svg>
)}

{shape === "dot" && (
  <svg width={size} height={size} viewBox="0 0 40 40" class={`pointer-events-none ${className}`} aria-hidden="true">
    <circle cx="20" cy="20" r="14" fill={colorVar} stroke="var(--color-ink)" stroke-width="3" />
  </svg>
)}

{shape === "plus" && (
  <svg width={size} height={size} viewBox="0 0 40 40" class={`pointer-events-none ${className}`} aria-hidden="true">
    <path
      d="M 16 4 H 24 V 16 H 36 V 24 H 24 V 36 H 16 V 24 H 4 V 16 H 16 Z"
      fill={colorVar}
      stroke="var(--color-ink)"
      stroke-width="3"
      stroke-linejoin="round"
    />
  </svg>
)}
