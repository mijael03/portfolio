---
// D24 — Ícono de stack inline desde Simple Icons (cierra F05 sin Figma).
// Mapea los iconSlug estilo devicon de data/skills.ts a íconos reales.
// Se renderiza en build (cero JS al cliente); hereda color via currentColor.
import {
  siTypescript,
  siPython,
  siDart,
  siPostgresql,
  siNextdotjs,
  siReact,
  siFlutter,
  siAndroid,
  siFastapi,
  siDjango,
  siNodedotjs,
  siNestjs,
  siMongodb,
  siRedis,
  siPrisma,
  siDocker,
  siVercel,
  siGoogle,
  type SimpleIcon,
} from "simple-icons";

interface Props {
  slug?: string;
  src?: string;
  size?: number;
}

const { slug, src, size = 15 } = Astro.props;

const bySlug: Record<string, SimpleIcon> = {
  typescript: siTypescript,
  python: siPython,
  dart: siDart,
  postgresql: siPostgresql,
  nextjs: siNextdotjs,
  react: siReact,
  flutter: siFlutter,
  android: siAndroid,
  fastapi: siFastapi,
  django: siDjango,
  nodejs: siNodedotjs,
  nestjs: siNestjs,
  mongodb: siMongodb,
  redis: siRedis,
  prisma: siPrisma,
  docker: siDocker,
  vercel: siVercel,
  google: siGoogle,
};

const icon = slug ? bySlug[slug] : undefined;
---

{
  icon ? (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d={icon.path} fill="currentColor"></path>
    </svg>
  ) : src ? (
    <img
      src={src}
      width={size}
      height={size}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="object-contain"
    />
  ) : (
    <span aria-hidden="true">□</span>
  )
}
