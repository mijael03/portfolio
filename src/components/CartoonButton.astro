---
type Variant = "cobalt" | "tomato" | "mustard" | "ink";

interface Props {
  href?: string;
  variant?: Variant;
  size?: "sm" | "md" | "lg";
  class?: string;
  /** Atributos extra (download, target, rel, aria-*, etc.) se pasan al tag */
  [key: string]: unknown;
}

const {
  href,
  variant = "cobalt",
  size = "md",
  class: className = "",
  ...rest
} = Astro.props;

const Tag = href ? "a" : "button";

const variantClasses: Record<Variant, string> = {
  cobalt: "bg-[var(--color-cobalt)] text-[var(--color-paper)] hover:bg-[var(--color-cobalt-deep)]",
  tomato: "bg-[var(--color-tomato)] text-[var(--color-paper)] hover:bg-[var(--color-tomato-deep)]",
  mustard: "bg-[var(--color-mustard)] text-[var(--color-ink)] hover:bg-[var(--color-mustard-deep)]",
  ink: "bg-[var(--color-ink)] text-[var(--color-paper)] hover:bg-[var(--color-ink-soft)]",
};

const sizeClasses: Record<NonNullable<Props["size"]>, string> = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-base",
  lg: "px-8 py-4 text-lg",
};
---

<Tag
  href={href}
  {...rest}
  class={`cartoon-btn inline-flex items-center gap-2 font-mono font-bold uppercase tracking-wider border-[3px] border-[var(--color-ink)] rounded-md transition-all duration-150 ${variantClasses[variant]} ${sizeClasses[size]} ${className}`}
  style="box-shadow: 5px 5px 0 0 var(--color-ink);"
>
  <slot />
</Tag>

<style>
  /* Fallback sin JS: hover/press en CSS puro. Cuando Motion engancha
     (.motion-enhanced) estos estados pasan a manejarse con springs. */
  .cartoon-btn:not(.motion-enhanced):hover {
    transform: translate(-1px, -1px);
    box-shadow: 7px 7px 0 0 var(--color-ink) !important;
  }

  .cartoon-btn:not(.motion-enhanced):active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 0 var(--color-ink) !important;
  }

  .cartoon-btn.motion-enhanced {
    transition-property: background-color, color;
  }
</style>

<script>
  // D26 — Spring physics en los botones (progressive enhancement sobre el CSS)
  import { animate, hover, press } from "motion";

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (!reducedMotion.matches) {
    const shadow = (n: number) => `${n}px ${n}px 0 0 var(--color-ink)`;
    const rest = { x: 0, y: 0, scale: 1, boxShadow: shadow(5) };
    const lifted = { x: -2, y: -2, scale: 1, boxShadow: shadow(7) };
    const pressed = { x: 4, y: 4, scale: 0.96, boxShadow: shadow(0) };
    const springSoft = { type: "spring", stiffness: 400, damping: 16 } as const;
    const springSnappy = { type: "spring", stiffness: 700, damping: 32 } as const;

    for (const btn of document.querySelectorAll<HTMLElement>(".cartoon-btn")) {
      btn.classList.add("motion-enhanced");

      hover(btn, () => {
        animate(btn, lifted, springSoft);
        return () => animate(btn, rest, springSoft);
      });

      press(btn, () => {
        animate(btn, pressed, springSnappy);
        return () => animate(btn, btn.matches(":hover") ? lifted : rest, springSoft);
      });
    }
  }
</script>
